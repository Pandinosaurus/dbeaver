<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>

<plugin>
    <extension point="org.jkiss.dbeaver.ui.propertyConfigurator">
        <propertyConfigurator class="org.jkiss.dbeaver.model.ai.engine.openai.OpenAIEngine" uiClass="org.jkiss.dbeaver.ui.ai.engine.openai.OpenAiConfigurator"/>
        <propertyConfigurator class="org.jkiss.dbeaver.model.ai.engine.copilot.CopilotCompletionEngine" uiClass="org.jkiss.dbeaver.ui.ai.engine.copilot.CopilotConfigurator"/>
    </extension>

    <extension point="org.eclipse.core.runtime.preferences">
        <initializer class="org.jkiss.dbeaver.ui.ai.preferences.AIPreferencesInitializer"/>
    </extension>

    <extension point="org.eclipse.core.expressions.definitions">
        <definition id="org.jkiss.dbeaver.ai.preferences">
            <instanceof value="org.jkiss.dbeaver.model.ai.AISettings"/>
        </definition>
        <!-- Enabled by the user -->
        <definition id="org.jkiss.dbeaver.core.ai.completion.enabled.by.user">
            <not>
                <test property="org.jkiss.dbeaver.ui.ai.isDisabled" forcePluginActivation="true" />
            </not>
        </definition>
    </extension>

    <extension point="org.eclipse.ui.preferencePages">
        <page id="org.jkiss.dbeaver.preferences.ai" class="org.jkiss.dbeaver.ui.ai.preferences.AIPreferencePageMain" name="%pref.page.ai.main.name">
            <keywordReference id="org.jkiss.dbeaver.core.keyword.dbeaver"/>
            <keywordReference id="dbeaver.ai.pref"/>
        </page>
        <page id="org.jkiss.dbeaver.preferences.ai.engines" category="org.jkiss.dbeaver.preferences.ai" class="org.jkiss.dbeaver.ui.ai.preferences.AIPreferencePageEngines" name="%pref.page.ai.engines.name">
            <keywordReference id="org.jkiss.dbeaver.core.keyword.dbeaver"/>
            <keywordReference id="dbeaver.ai.pref"/>
        </page>
        <page id="org.jkiss.dbeaver.preferences.ai.config" category="org.jkiss.dbeaver.preferences.ai" class="org.jkiss.dbeaver.ui.ai.preferences.AIPreferencePageConfiguration" name="%pref.page.ai.config.name">
            <keywordReference id="org.jkiss.dbeaver.core.keyword.dbeaver"/>
            <keywordReference id="dbeaver.ai.pref"/>
            <keywordReference id="dbeaver.ai.config"/>
        </page>
        <page id="org.jkiss.dbeaver.preferences.ai.prompts" category="org.jkiss.dbeaver.preferences.ai" class="org.jkiss.dbeaver.ui.ai.preferences.AIPreferencePagePrompts" name="%pref.page.ai.prompts.name">
            <keywordReference id="org.jkiss.dbeaver.core.keyword.dbeaver"/>
            <keywordReference id="dbeaver.ai.pref"/>
            <keywordReference id="dbeaver.ai.prompts"/>
        </page>
    </extension>
    <extension point="org.eclipse.ui.propertyPages">
        <page id="org.jkiss.dbeaver.preferences.ai.engines" class="org.jkiss.dbeaver.ui.ai.preferences.AIPreferencePageEngines" name="%pref.page.ai.engines.name">
            <enabledWhen><reference definitionId="org.jkiss.dbeaver.ai.preferences"/></enabledWhen>
        </page>
        <page id="org.jkiss.dbeaver.preferences.ai.config" class="org.jkiss.dbeaver.ui.ai.preferences.AIPreferencePageConfiguration" name="%prop.page.ai.config.name">
            <enabledWhen><reference definitionId="org.jkiss.dbeaver.ai.preferences"/></enabledWhen>
        </page>
        <page id="org.jkiss.dbeaver.preferences.ai.prompts" class="org.jkiss.dbeaver.ui.ai.preferences.AIPreferencePagePrompts" name="%pref.page.ai.prompts.name">
            <enabledWhen><reference definitionId="org.jkiss.dbeaver.ai.preferences"/></enabledWhen>
        </page>
    </extension>

    <extension point="org.eclipse.core.expressions.propertyTesters">
        <propertyTester class="org.jkiss.dbeaver.ui.ai.AIPropertyTester"
                        id="org.jkiss.dbeaver.ui.ai.AIPropertyTester"
                        namespace="org.jkiss.dbeaver.ui.ai"
                        properties="isDisabled"
                        type="java.lang.Object"/>
    </extension>

    <extension point="org.eclipse.ui.commands">
        <category id="com.dbeaver.ai" name="AI commands" description="AI commands"/>
        <command id="org.jkiss.dbeaver.ui.ai.showCompletion" name="%command.org.jkiss.dbeaver.ui.ai.showCompletion.name" description="%command.org.jkiss.dbeaver.ui.ai.showCompletion.description" categoryId="com.dbeaver.ai"/>
        <command id="org.jkiss.dbeaver.ui.ai.configuration" name="%command.org.jkiss.dbeaver.ui.ai.configuration.name" description="%command.org.jkiss.dbeaver.ui.ai.configuration.description" categoryId="com.dbeaver.ai"/>
        <command id="com.dbeaver.ai.chat.sendPrompt" name="Send" description="Send prompt to AI engine" categoryId="com.dbeaver.ai"/>
        <command id="com.dbeaver.ai.chat.attach" name="Attach" description="Attach file" categoryId="com.dbeaver.ai"/>
        <command id="com.dbeaver.ai.chat.toggle" name="AI Chat" description="Toggle AI Chat visibility" categoryId="com.dbeaver.ai"/>
    </extension>

    <extension point="org.eclipse.ui.menus">
        <menuContribution allPopups="false" locationURI="menu:SQLEditorMenu?after=query">
            <command commandId="org.jkiss.dbeaver.ui.ai.showCompletion">
                <visibleWhen checkEnabled="true"/>
            </command>
        </menuContribution>
        <menuContribution allPopups="false" locationURI="toolbar:org.jkiss.dbeaver.ui.editors.sql.toolbar.side.top?after=tools" >
            <command commandId="org.jkiss.dbeaver.ui.ai.showCompletion">
                <visibleWhen>
                    <and>
                        <reference definitionId="org.jkiss.dbeaver.core.ai.completion.enabled.by.user"/>
                        <reference definitionId="org.jkiss.dbeaver.core.ai.completion.enabled.by.policy"/>
                        <test property="org.jkiss.dbeaver.ui.toolbar.configuration.visible" args="sqlEditor.side.top,org.jkiss.dbeaver.ui.ai.showCompletion"/>
                    </and>
                </visibleWhen>
            </command>
        </menuContribution>
        <menuContribution allPopups="false" locationURI="menu:window?before=primary.views">
            <command commandId="com.dbeaver.ai.chat.toggle" style="toggle">
                <visibleWhen checkEnabled="true"/>
            </command>
        </menuContribution>
        <menuContribution allPopups="false" locationURI="toolbar:dbeaver-general?after=sql_tools">
            <command commandId="com.dbeaver.ai.chat.toggle" id="ai.dropdown.menu" style="pulldown">
                <visibleWhen checkEnabled="true"/>
            </command>
            <separator name="ai" visible="true"/>
        </menuContribution>
        <menuContribution allPopups="false" locationURI="menu:ai.dropdown.menu">
            <command commandId="org.jkiss.dbeaver.ui.ai.showCompletion"/>
            <separator name="configuration" visible="true"/>
            <command commandId="org.jkiss.dbeaver.ui.ai.configuration"/>
            <!--            <dynamic id="org.jkiss.dbeaver.core.menu.newConnection.select" class="org.jkiss.dbeaver.ui.actions.datasource.NewConnectionDriverSelectorContributor"/>-->
        </menuContribution>

    </extension>

    <extension point="org.eclipse.ui.activities">
        <activity id="dbeaver.ai.activity.policy" name="AI Activity (Policy)">
            <enabledWhen>
                <reference definitionId="org.jkiss.dbeaver.core.ai.completion.enabled.by.policy"/>
            </enabledWhen>
        </activity>
        <activity id="dbeaver.ai.activity" name="AI Activity">
            <enabledWhen>
                <and>
                    <reference definitionId="org.jkiss.dbeaver.core.ai.completion.enabled.by.user"/>
                    <reference definitionId="org.jkiss.dbeaver.core.ai.completion.enabled.by.policy"/>
                </and>
            </enabledWhen>
        </activity>

        <activityPatternBinding activityId="dbeaver.ai.activity.policy" pattern="org.jkiss.dbeaver.ui.ai.*"/>
        <activityPatternBinding activityId="dbeaver.ai.activity.policy" pattern="org.jkiss.dbeaver.preferences.ai"/>
        <activityPatternBinding activityId="dbeaver.ai.activity" pattern="org.jkiss.dbeaver.ui.ai/org.jkiss.dbeaver.ai.*"/>
    </extension>

    <extension point="org.eclipse.ui.commandImages">
        <image commandId="org.jkiss.dbeaver.ui.ai.showCompletion" icon="platform:/plugin/org.jkiss.dbeaver.model.ai/icons/ai.svg"/>
        <image commandId="com.dbeaver.ai.chat.sendPrompt" icon="platform:/plugin/org.jkiss.dbeaver.model.ai/icons/ai-chat-send.svg"/>
        <image commandId="com.dbeaver.ai.chat.attach" icon="platform:/plugin/org.jkiss.dbeaver.model.ai/icons/attach.svg"/>
        <image commandId="com.dbeaver.ai.chat.toggle" icon="platform:/plugin/org.jkiss.dbeaver.model.ai/icons/ai.svg"/>
    </extension>

    <extension point="org.eclipse.ui.handlers">
        <handler commandId="org.jkiss.dbeaver.ui.ai.showCompletion" class="org.jkiss.dbeaver.ui.ai.internal.AITranslateHandler"/>
        <handler commandId="org.jkiss.dbeaver.ui.ai.configuration" class="org.jkiss.dbeaver.ui.ai.internal.AIConfigurationHandler"/>
        <handler commandId="com.dbeaver.ai.chat.sendPrompt" class="org.jkiss.dbeaver.ui.ai.chat.commands.AIChatSendPromptHandler"/>
        <handler commandId="com.dbeaver.ai.chat.attach" class="org.jkiss.dbeaver.ui.ai.chat.commands.AIChatAttachHandler"/>
        <handler commandId="com.dbeaver.ai.chat.toggle" class="org.jkiss.dbeaver.ui.ai.chat.commands.AIChatToggleHandler">
            <enabledWhen>
                <and>
                    <reference definitionId="org.jkiss.dbeaver.core.ai.completion.enabled.by.user"/>
                    <reference definitionId="org.jkiss.dbeaver.core.ai.completion.enabled.by.policy"/>
                </and>
            </enabledWhen>
        </handler>
    </extension>

    <extension point="org.eclipse.ui.bindings">
        <key commandId="org.jkiss.dbeaver.ui.ai.showCompletion" contextId="org.eclipse.ui.contexts.window" schemeId="org.eclipse.ui.defaultAcceleratorConfiguration" sequence="CTRL+I"/>
        <key commandId="com.dbeaver.ai.chat.sendPrompt" contextId="com.dbeaver.ai.chat" schemeId="org.eclipse.ui.defaultAcceleratorConfiguration" sequence="M1+Enter"/>
    </extension>


    <extension point="org.jkiss.dbeaver.toolBarConfiguration">
        <toolBar key="sqlEditor.side.top">
            <item commandId="org.jkiss.dbeaver.ui.ai.showCompletion" defaultVisibility="true"/>
        </toolBar>
    </extension>

    <extension point="org.eclipse.ui.keywords">
        <keyword id="dbeaver.ai.pref" label="%keyword.org.jkiss.dbeaver.ai.pref"/>
        <keyword id="dbeaver.ai.config" label="%keyword.org.jkiss.dbeaver.ai.config"/>
        <keyword id="dbeaver.ai.prompts" label="%keyword.org.jkiss.dbeaver.ai.prompts"/>
    </extension>
    <extension point="org.jkiss.dbeaver.workbenchHandler">
        <workbenchWindowInitializer class="org.jkiss.dbeaver.ui.ai.AIWorkbenchInitializer" order="2"/>
    </extension>


    <extension point="org.eclipse.ui.themes">
        <themeElementCategory label="%themeElementCategory.org.jkiss.dbeaver.ui.sqlPresentation.aiChat.label"
                              id="org.jkiss.dbeaver.ui.sqlPresentation.aiChat">
            <description>%themeElementCategory.org.jkiss.dbeaver.ui.sqlPresentation.aiChat.description</description>
        </themeElementCategory>

        <colorDefinition
            label="%colorDefinition.org.jkiss.dbeaver.ui.sqlPresentation.aiChat.color.prompt.background.label"
            categoryId="org.jkiss.dbeaver.ui.sqlPresentation.aiChat"
            id="org.jkiss.dbeaver.ui.sqlPresentation.aiChat.color.prompt.background"
            value="224,235,242">
            <description>%colorDefinition.org.jkiss.dbeaver.ui.sqlPresentation.aiChat.color.prompt.background.description</description>
        </colorDefinition>
        <colorDefinition
            label="%colorDefinition.org.jkiss.dbeaver.ui.sqlPresentation.aiChat.color.prompt.border.label"
            categoryId="org.jkiss.dbeaver.ui.sqlPresentation.aiChat"
            id="org.jkiss.dbeaver.ui.sqlPresentation.aiChat.color.prompt.border"
            value="189,220,240">
            <description>%colorDefinition.org.jkiss.dbeaver.ui.sqlPresentation.aiChat.color.prompt.border.description</description>
        </colorDefinition>
    </extension>

    <extension point="org.eclipse.e4.ui.css.swt.theme">
        <stylesheet uri="css/e4-dark_ai_prefstyle.css">
            <themeid refid="org.eclipse.e4.ui.css.theme.e4_dark"/>
        </stylesheet>
    </extension>

    <extension point="org.eclipse.ui.contexts">
        <context id="com.dbeaver.ai.chat" parentId="org.eclipse.ui.contexts.window" name="AI chat" description="AI chat window"/>
    </extension>

    <extension point="org.eclipse.ui.views">
        <view id="com.dbeaver.ai.chat"
              category="org.jkiss.dbeaver.core.category"
              class="org.jkiss.dbeaver.ui.ai.chat.AIChatView"
              icon="platform:/plugin/org.jkiss.dbeaver.model.ai/icons/ai.svg"
              name="Chat">
            <description>AI Chat</description>
        </view>
    </extension>

    <extension point="org.eclipse.ui.perspectiveExtensions">
        <perspectiveExtension targetID="org.jkiss.dbeaver.core.perspective">
            <view id="com.dbeaver.ai.chat" relative="org.eclipse.ui.views.ContentOutline" relationship="stack" visible="false" minimized="true"/>
            <viewShortcut id="com.dbeaver.ai.chat"/>
        </perspectiveExtension>
    </extension>

</plugin>
